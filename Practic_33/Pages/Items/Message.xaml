<UserControl x:Class="Practic_33.Pages.Items.Message"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Practic_33.Pages.Items"
             mc:Ignorable="d">
    <Grid Background="#FFF7F7F7">
        <!-- Аватар пользователя (круглое изображение 30x30) -->
        <Image
            x:Name="imgUser"
            Margin="10, 10, 0, 0"
            Width="30"
            Height="30"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Source="/Images/ic-user.png">
            <!-- Скругление углов изображения (делает его круглым) -->
            <Image.Clip>
                <RectangleGeometry
                    RadiusX="15"
                    RadiusY="15"
                    Rect="0,0,30,30"/>
            </Image.Clip>
        </Image>

        <!-- ФИО пользователя (жирный шрифт, сверху) -->
        <Label
            x:Name="FIO"
            Content="Иванов Иван Иванович"
            Margin="45, 0, 0, 0"
            VerticalAlignment="Top"
            FontWeight="Bold"
            FontSize="10"/>

        <!-- Область для текста сообщения (обертка с переносом строк) -->
        <TextBlock
            x:Name="tbMessage"
            Margin="50, 26, 0, 10"
            TextWrapping="Wrap"/>
    </Grid>
</UserControl>
